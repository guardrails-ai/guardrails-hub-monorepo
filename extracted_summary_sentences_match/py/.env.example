# Environment variables for guardrails-ai-extracted-summary-sentences-match
# Copy to .env and fill in real values before running the tests.

# OpenAI API key — this validator calls an LLM at runtime. (required)
OPENAI_API_KEY=sk-...

# Optional OpenAI-compatible base URL (defaults to OpenAI). (optional)
OPENAI_API_BASE=https://api.openai.com/v1
