# =============================================================================
# Consolidated local-dev environment for guardrails-hub-monorepo.
#
# Copy this file to `.env` (which is gitignored) and fill in real values, then
# load it before running a package's tests, e.g.:
#
#   set -a && source .env && set +a
#   cd <name>/py && make test
#
# Each variable is only used by the validators listed next to it. Per-package
# templates live in <name>/py/.env.example.
# =============================================================================

# OpenAI API key — LLM-backed validators.
#   detect_prompt_injection, extracted_summary_sentences_match, llm_critic,
#   politeness_check, prompt_injection_detector, provenance_llm,
#   qa_relevance_llm_eval, relevancy_evaluator, response_evaluator,
#   responsiveness_check, saliency_check, unusual_prompt
OPENAI_API_KEY=sk-...

# Optional OpenAI-compatible base URL (defaults to OpenAI).
#   extracted_summary_sentences_match
OPENAI_API_BASE=

# Anthropic API key — reserved for litellm-backed validators.
ANTHROPIC_API_KEY=sk-ant-...

# Google Maps API key — address validation/geocoding.
#   valid_address
GOOGLE_MAPS_API_KEY=AIza...

# Hugging Face token — required for gated/private models. In GitHub Actions this
# is stored as the secret HUGGINGFACE_API_KEY and exposed to tests as HF_TOKEN.
#   shieldgemma_2b, llamaguard_7b, detect_jailbreak, provenance_nli
HF_TOKEN=hf_...

# Optional model source override (defaults to "s3").
#   detect_jailbreak
MODEL_PATH=
